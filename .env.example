# Shared
APP_ENV=development

# Backend
DATABASE_URL=sqlite:///./preterm.db
JWT_SECRET=change-me
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
APP_WORKERS=1
LOG_LEVEL=info
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SERVE_FRONTEND=false
FRONTEND_DIST_DIR=../frontend/dist
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
FRED_API_KEY=
FRED_API_BASE=https://api.stlouisfed.org/fred
ENABLE_YFINANCE=true
ENABLE_EDGAR=true
SEC_DATA_API_BASE=https://data.sec.gov
SEC_USER_AGENT=PreTerm/0.1 your-email@example.com
MARKET_DATA_PROVIDER=seeded
MARKET_DATA_REFRESH_SECONDS=300
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_MARKET_LIMIT=18
KALSHI_MARKET_STATUS=open
KALSHI_SERIES_FILTER=
KALSHI_FALLBACK_TO_SEEDED=true
KALSHI_REQUEST_TIMEOUT_SECONDS=10

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000
# Production on Vercel (multi-service): use /_/backend or leave unset (frontend defaults in prod)
# VITE_API_URL=/_/backend
VITE_BASE_PATH=/
